// The FH Dashboard add-on's starter dashboard, seeded into the add-on config
// dir on first start — from then on it is YOURS to edit (changes to existing
// files hot-reload; a brand-new *.pkl entry needs an add-on restart, see
// DOCS.md).
//
// It references NO concrete entities: every section is a live query
// (DynamicGroup) over whatever this Home Assistant instance has, so it renders
// on any installation. For entity-specific cards, import the generated typed
// dump (`import "lib/dump.pkl" as dump`) and reference
// `dump.entities.<your_entity>` — see the lib/ modules for the full card set.

amends "lib/entry.pkl"

import "lib/components.pkl" as c

title = "Home"

card = (c.column) {
  children {
    c.title("Lights")
    new c.DynamicGroup {
      query = c.domainIs("light")
      // Lights that are on get a brightness slider; the rest a toggle card.
      branches {
        [c.stateIs("on")] = c.slider
      }
      render = (e) -> (c.entityCard(e)) { tap = c.toggleTap }
    }

    c.title("Switches")
    new c.DynamicGroup {
      query = c.domainIs("switch")
      render = (e) -> (c.entityCard(e)) { tap = c.toggleTap }
    }

    c.title("Low battery")
    new c.DynamicGroup {
      query = c.lowBattery(20)
      render = (e) -> (c.entityCard(e)) {
        label = c.expr(#"$attr.friendly_name & " — " & $state & "%""#)
        secondary = "device_class"
      }
    }
  }
}
