/// Your home's data package — what `@fh-home` points at.
///
/// The add-on regenerates `dump.pkl` beside this file on every start, typed
/// against your live Home Assistant registry, so `dump.entities.<name>` is a
/// real, checked reference to a real device. Import it as:
///
///   import "@fh-home/dump.pkl" as dump
///
/// This directory starts out holding only this file: there is no dump until the
/// add-on has talked to Home Assistant once. Don't edit `dump.pkl` — it is
/// overwritten at every start. This file itself needs no attention.
amends "pkl:Project"

package {
  name = "fh-home"
  baseUri = "package://fh.local/fh-home"
  version = "1.0.0"
  packageZipUrl = "https://fh.local/fh-home@\(version).zip"
}

dependencies {
  ["fh-dashboard"] = import("../lib/PklProject")
}
