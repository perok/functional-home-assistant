                "transform" : "$attr.friendly_name ? $attr.friendly_name : $entity_id"
              },
              "max" : {
                "bypassUnavailable" : false,
                "reactive" : false,
                "transform" : "$lookup({\"light\":255,\"cover\":100,\"fan\":100}, $domain)"
              },
              "min" : {
                "bypassUnavailable" : false,
                "reactive" : false,
                "transform" : "$lookup({\"light\":1,\"cover\":0,\"fan\":0}, $domain)"
              },
              "state" : {
                "bypassUnavailable" : true,
                "reactive" : true,
                "transform" : "$state"
              },
              "value" : {
                "bypassUnavailable" : false,
                "default" : "0",
                "reactive" : true,
                "transform" : "$lookup($attr, $lookup({\"light\":\"brightness\",\"cover\":\"current_position\",\"fan\":\"percentage\"}, $domain))"
              }
            },
            "when" : {
              "kind" : "cmp",
              "op" : "eq",
              "property" : "domain",
              "value" : "light"
            }
          },
