          "tappable" : "1",
          "value" : {
            "bypassUnavailable" : true,
            "reactive" : true,
            "transform" : "$round($number($state), 1) & \" V\""
          }
        }
      },
      {
        "card" : "slider",
        "children" : [
        ],
        "kind" : "component",
