  "theme" : {
    "chrome" : "<main class=\"responsive\" id=\"dashboard\">{{{body}}}</main>\n<div id=\"popups\"></div>",
    "scripts" : [
      "https://cdn.jsdelivr.net/npm/beercss@4.0.23/dist/cdn/beer.min.js"
    ],
    "styles" : "/* MD3 role palette ([[md3Light]]/[[md3Dark]], late-bound). Body\n   specificity + all three class states + declaration order: see the\n   module doc for why each is required. */\nbody,body.light,body.dark{--primary:#006493;--on-primary:#ffffff;--primary-container:#cae6ff;--on-primary-container:#001e30;--secondary:#50606e;--on-secondary:#ffffff;--secondary-container:#d3e5f5;--on-secondary-container:#0c1d29;--tertiary:#65587b;--on-tertiary:#ffffff;--tertiary-container:#ebddff;--on-tertiary-container:#201634;--error:#ba1a1a;--on-error:#ffffff;--error-container:#ffdad6;--on-error-container:#410002;--background:#fcfcff;--on-background:#1a1c1e;--surface:#fcfcff;--on-surface:#1a1c1e;--surface-variant:#dde3ea;--on-surface-variant:#41474d;--outline:#72787e;--outline-variant:#c1c7ce;--shadow:#000000;--scrim:#000000;--inverse-surface:#2e3133;--inverse-on-surface:#f0f0f3;--inverse-primary:#8dcdff;--surface-dim:#d9dadd;--surface-bright:#f9f9fc;--surface-container-lowest:#ffffff;--surface-container-low:#f3f3f6;--surface-container:#edeef1;--surface-container-high:#e8e8eb;--surface-container-highest:#e2e2e5}\n@media (prefers-color-scheme:dark){\n  body,body.light,body.dark{--primary:#8dcdff;--on-primary:#00344f;--primary-container:#004b70;--on-primary-container:#cae6ff;--secondary:#b7c9d9;--on-secondary:#22323f;--secondary-container:#384956;--on-secondary-container:#d3e5f5;--tertiary:#cfc0e8;--on-tertiary:#362b4b;--tertiary-container:#4d4162;--on-tertiary-container:#ebddff;--error:#ffb4ab;--on-error:#690005;--error-container:#93000a;--on-error-container:#ffb4ab;--background:#1a1c1e;--on-background:#e2e2e5;--surface:#1a1c1e;--on-surface:#e2e2e5;--surface-variant:#41474d;--on-surface-variant:#c1c7ce;--outline:#8b9198;--outline-variant:#41474d;--shadow:#000000;--scrim:#000000;--inverse-surface:#e2e2e5;--inverse-on-surface:#2e3133;--inverse-primary:#006493;--surface-dim:#111416;--surface-bright:#37393c;--surface-container-lowest:#0c0e11;--surface-container-low:#1a1c1e;--surface-container:#1e2022;--surface-container-high:#282a2d;--surface-container-highest:#333537}\n}\n/* HA-token re-pointing — LAST so it wins in both schemes. Keeps the HA\n   look on MD3: HA blue as primary, HA background/text/divider, and the\n   card/dialog surfaces (article reads --surface-container-low, dialog\n   --surface-container-high) on the HA card color. */\nbody,body.light,body.dark{\n  --primary:var(--primary-color);\n  --on-primary:var(--text-primary-color);\n  --background:var(--primary-background-color);\n  --surface:var(--primary-background-color);\n  --on-background:var(--primary-text-color);\n  --on-surface:var(--primary-text-color);\n  --on-surface-variant:var(--secondary-text-color);\n  --outline-variant:var(--divider-color);\n  --error:var(--error-color);\n  --surface-container-low:var(--card-background-color);\n  --surface-container-high:var(--card-background-color);\n}\n\n/* Contract CSS BeerCSS doesn't cover (cards/buttons/dialogs/sliders it\n   styles as elements). The fh- LAYOUT contract (grid/row/col/cell spans)\n   is the shared framework-agnostic default from theme.pkl. */\n.fh-grid,.fh-group{display:flex;flex-wrap:wrap;justify-content:center;gap:var(--fh-gap,1rem)}\n.fh-grid.fh-start,.fh-group.fh-start{justify-content:flex-start}\n.fh-grid>:where(.fh-cell),.fh-group>:where(.fh-cell){flex:0 1 calc((100% + var(--fh-gap,1rem)) * 4 / 12 - var(--fh-gap,1rem));min-width:0}.fh-cols-1{flex-basis:calc((100% + var(--fh-gap,1rem)) * 1 / 12 - var(--fh-gap,1rem))}\n.fh-cols-2{flex-basis:calc((100% + var(--fh-gap,1rem)) * 2 / 12 - var(--fh-gap,1rem))}\n.fh-cols-3{flex-basis:calc((100% + var(--fh-gap,1rem)) * 3 / 12 - var(--fh-gap,1rem))}\n.fh-cols-4{flex-basis:calc((100% + var(--fh-gap,1rem)) * 4 / 12 - var(--fh-gap,1rem))}\n.fh-cols-5{flex-basis:calc((100% + var(--fh-gap,1rem)) * 5 / 12 - var(--fh-gap,1rem))}\n.fh-cols-6{flex-basis:calc((100% + var(--fh-gap,1rem)) * 6 / 12 - var(--fh-gap,1rem))}\n.fh-cols-7{flex-basis:calc((100% + var(--fh-gap,1rem)) * 7 / 12 - var(--fh-gap,1rem))}\n.fh-cols-8{flex-basis:calc((100% + var(--fh-gap,1rem)) * 8 / 12 - var(--fh-gap,1rem))}\n.fh-cols-9{flex-basis:calc((100% + var(--fh-gap,1rem)) * 9 / 12 - var(--fh-gap,1rem))}\n.fh-cols-10{flex-basis:calc((100% + var(--fh-gap,1rem)) * 10 / 12 - var(--fh-gap,1rem))}\n.fh-cols-11{flex-basis:calc((100% + var(--fh-gap,1rem)) * 11 / 12 - var(--fh-gap,1rem))}\n.fh-cols-12{flex-basis:calc((100% + var(--fh-gap,1rem)) * 12 / 12 - var(--fh-gap,1rem))}\n.fh-cols-full{flex-basis:100%}\n.fh-row{display:flex;gap:var(--fh-gap,1rem);flex-wrap:wrap}\n.fh-row>.fh-cell{flex:1 1 0;min-width:0;align-self:flex-start}\n.fh-col{display:flex;flex-direction:column;gap:var(--fh-gap,1rem)}\n.fh-col>.fh-cell{width:100%}\n@media (max-width:640px){.fh-grid>.fh-cell,.fh-group>.fh-cell{flex-basis:100%}}\n.section{color:var(--primary)}\n.state{color:var(--on-surface-variant)}\n.entity .secondary{display:block;font-size:.8em;color:var(--on-surface-variant)}\n/* Domain icon in the entity-card header (Material Symbols — the font\n   ships in the BeerCSS dist). */\n.entity header i{font-size:1.25rem;vertical-align:text-bottom;margin-inline-end:.375rem;color:var(--primary)}\n.card.tappable{cursor:pointer}\n/* The slider card's label line (class contract, like .card): label left,\n   live state right. */\n.slider-head{display:flex;gap:.75rem;align-items:baseline;justify-content:space-between}\n/* Tabs: the bar is BeerCSS's native `.tabs > a` element — even tab\n   distribution, underline active indicator, hover/press states, all\n   framework CSS (an inline-size override to make tabs hug their labels\n   was tried and REVERTED: it detached the active underline from the\n   anchor). Only the panel wrapper is ours. */\n.tab-panel{display:contents}\n\n/* Popup: BeerCSS's <dialog> styling (fixed, centered, elevated,\n   surface-container-high) does the chrome; cap the width and unfill the ✕\n   (a bare <button> is a filled primary pill by default). */\ndialog.popup{max-inline-size:min(90vw,32rem)}\n.popup-close{position:absolute;top:.5rem;right:.5rem;background:transparent;\n  color:var(--on-surface-variant);block-size:auto;padding:.25rem .5rem;font-size:1rem}",
    "stylesheets" : [
      "https://cdn.jsdelivr.net/npm/beercss@4.0.23/dist/cdn/beer.min.css"
    ],
    "tokens" : {
      "accent-color" : "#ff9800",
      "card-background-color" : "#ffffff",
      "disabled-text-color" : "#bdbdbd",
      "divider-color" : "rgba(0, 0, 0, 0.12)",
      "error-color" : "#db4437",
      "ha-card-border-radius" : "12px",
      "info-color" : "#039be5",
      "primary-background-color" : "#fafafa",
      "primary-color" : "#03a9f4",
      "primary-text-color" : "#212121",
      "secondary-background-color" : "#e5e5e5",
      "secondary-text-color" : "#727272",
      "success-color" : "#43a047",
      "text-primary-color" : "#ffffff",
      "warning-color" : "#ffa600"
    },
    "tokensDark" : {
      "card-background-color" : "#1e1e1e",
      "disabled-text-color" : "#6f6f6f",
      "divider-color" : "rgba(255, 255, 255, 0.12)",
      "primary-background-color" : "#111111",
      "primary-text-color" : "#e1e1e1",
      "secondary-background-color" : "#1c1c1c",
      "secondary-text-color" : "#9e9e9e"
    }
  }
