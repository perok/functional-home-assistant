      {
        "card" : "entityCard",
        "children" : [
        ],
        "kind" : "component",
        "slots" : {
          "entity_id" : "sensor.ams_1a4e_q",
          "label" : "Power",
          "value" : {
            "bypassUnavailable" : true,
            "reactive" : true,
            "transform" : "$state & ($attr.unit_of_measurement ? \" \" & $attr.unit_of_measurement : \"\")"
          }
        }
