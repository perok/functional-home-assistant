              },
              "value" : {
                "bypassUnavailable" : true,
                "reactive" : true,
                "transform" : "$state & ($attr.unit_of_measurement ? \" \" & $attr.unit_of_measurement : \"\")"
              }
            },
            "when" : {
              "kind" : "cmp",
              "op" : "ne",
              "property" : "domain",
              "value" : "__never__"
            }
