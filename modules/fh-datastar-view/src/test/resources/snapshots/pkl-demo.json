  "cards" : {
    "button" : {
      "slots" : [
        "label",
        "onclick"
      ],
      "template" : "<button class=\"card\" data-on:click=\"{{{onclick}}}\">{{label}}</button>"
    },
    "entityCard" : {
      "slots" : [
        "label",
        "value",
        "entity_id"
      ],
      "template" : "<article class=\"card entity{{#tappable}} tappable{{/tappable}}\"{{#tappable}}\n  data-on:click=\"{{{onclick}}}\"{{/tappable}}>\n  <header>{{#icon}}<i>{{icon}}</i>{{/icon}}{{label}}</header>\n  <span class=\"state\">{{value}}</span>{{#secondary}}\n  <span class=\"secondary\">{{secondary}}</span>{{/secondary}}\n</article>"
    },
    "fhcol" : {
      "slots" : [
      ],
      "template" : "<div class=\"fh-col{{#class}} {{class}}{{/class}}\">{{#children}}{{{html}}}{{/children}}</div>"
    },
    "fhgrid" : {
      "slots" : [
      ],
      "template" : "<div class=\"fh-grid{{#class}} {{class}}{{/class}}\">{{#children}}{{{html}}}{{/children}}</div>"
    },
    "fhrow" : {
      "slots" : [
      ],
      "template" : "<div class=\"fh-row{{#class}} {{class}}{{/class}}\">{{#children}}{{{html}}}{{/children}}</div>"
    },
    "ifhost" : {
      "slots" : [
      ],
      "template" : "<div id=\"{{id}}\">{{{branch}}}</div>"
    },
    "popup" : {
      "slots" : [
      ],
      "template" : "<dialog open class=\"popup\"><button class=\"popup-close\" data-on:click=\"@post('sse/popup/close')\">✕</button>{{#children}}{{{html}}}{{/children}}</dialog>"
    },
    "sectionTitle" : {
      "slots" : [
        "label"
      ],
      "template" : "<h2 class=\"section\">{{label}}</h2>"
    },
    "slider" : {
      "slots" : [
        "label",
        "state",
        "value",
        "action",
        "min",
        "max",
        "key",
        "entity_id"
      ],
      "template" : "<article class=\"card\">\n  <div class=\"slider-head\"><strong>{{label}}</strong><span class=\"state\">{{state}}</span></div>\n  <div class=\"slider max\" style=\"--_start: 0%;--_end: {{fill}}%\">\n    <input type=\"range\" min=\"{{min}}\" max=\"{{max}}\"\n      data-signals=\"{ val_{{id}}: {{value}} }\"\n      data-bind=\"val_{{id}}\"\n      data-on:change=\"@post('sse/action/{{{action}}}/{{{entity_id}}}/{{key}}/' + $val_{{id}})\" />\n    <span></span>\n  </div>\n</article>"
    },
    "tab" : {
      "slots" : [
        "label",
        "onclick",
        "active"
      ],
      "template" : "<a data-on:click=\"{{{onclick}}}\" data-class=\"{active: {{{active}}}}\">{{label}}</a>",
      "wrapAsCell" : false
    },
    "tabs" : {
      "slots" : [
      ],
      "template" : "<div class=\"fh-col\">\n  <div class=\"tabs\">\n    {{#children}}{{{html}}}{{/children}}\n  </div>\n  <div id=\"{{id}}_panel\" class=\"tab-panel\" data-signals=\"{ tab_{{id}}: {{bakeIndex}} }\">\n    {{{panel}}}\n  </div>\n</div>"
    }
  },
