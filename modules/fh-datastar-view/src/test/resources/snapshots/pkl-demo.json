          "action" : "light/turn_on",
          "entity_id" : "light.skyconnect_v1_0_light_group_overetasje_stue_sittegruppe_gang",
          "key" : "brightness",
          "label" : "Demo light",
          "max" : "255",
          "min" : "1",
          "state" : {
            "bypassUnavailable" : true,
            "reactive" : true,
            "transform" : "$state"
          },
          "value" : {
            "bypassUnavailable" : false,
            "default" : "0",
            "reactive" : true,
            "transform" : "$attr.brightness"
          }
        }
      },
      {
        "card" : "sectionTitle",
        "children" : [
        ],
        "kind" : "component",
        "slots" : {
          "label" : "Active now"
        }
      },
      {
        "cases" : [
          {
            "card" : "slider",
            "slots" : {
              "action" : {
                "bypassUnavailable" : false,
                "reactive" : false,
                "transform" : "$lookup({\"light\":\"light/turn_on\",\"cover\":\"cover/set_cover_position\",\"fan\":\"fan/set_percentage\"}, $domain)"
              },
              "key" : {
                "bypassUnavailable" : false,
                "reactive" : false,
                "transform" : "$lookup({\"light\":\"brightness\",\"cover\":\"position\",\"fan\":\"percentage\"}, $domain)"
              },
              "label" : {
                "bypassUnavailable" : false,
                "reactive" : true,
                "transform" : "$attr.friendly_name ? $attr.friendly_name : $entity_id"
              },
              "max" : {
                "bypassUnavailable" : false,
                "reactive" : false,
                "transform" : "$lookup({\"light\":255,\"cover\":100,\"fan\":100}, $domain)"
              },
              "min" : {
                "bypassUnavailable" : false,
                "reactive" : false,
                "transform" : "$lookup({\"light\":1,\"cover\":0,\"fan\":0}, $domain)"
              },
              "state" : {
                "bypassUnavailable" : true,
                "reactive" : true,
                "transform" : "$state"
              },
              "value" : {
                "bypassUnavailable" : false,
                "default" : "0",
                "reactive" : true,
                "transform" : "$lookup($attr, $lookup({\"light\":\"brightness\",\"cover\":\"current_position\",\"fan\":\"percentage\"}, $domain))"
              }
            },
            "when" : {
              "kind" : "cmp",
              "op" : "eq",
              "property" : "domain",
              "value" : "light"
            }
          },
          {
            "card" : "entityCard",
            "slots" : {
              "label" : {
                "bypassUnavailable" : false,
                "reactive" : true,
                "transform" : "$attr.friendly_name & \" (\" & $state & \")\""
              },
              "onclick" : {
                "bypassUnavailable" : false,
                "reactive" : false,
                "transform" : "\"@post('/sse/action/\" & (($a := $lookup({\"scene\": \"scene/turn_on\", \"script\": \"script/turn_on\", \"button\": \"button/press\", \"input_button\": \"input_button/press\"}, $domain); $a ? $a : \"homeassistant/toggle\")) & \"/\" & $entity_id & \"')\""
              },
              "tappable" : "1",
              "value" : {
                "bypassUnavailable" : true,
                "reactive" : true,
                "transform" : "$state & ($attr.unit_of_measurement ? \" \" & $attr.unit_of_measurement : \"\")"
              }
            },
            "when" : {
              "kind" : "cmp",
              "op" : "ne",
              "property" : "domain",
              "value" : "__never__"
            }
          }
        ],
        "kind" : "dynamic",
        "query" : {
          "kind" : "cmp",
          "op" : "eq",
          "property" : "state",
          "value" : "on"
        }
      },
      {
        "card" : "sectionTitle",
        "children" : [
        ],
        "kind" : "component",
        "slots" : {
          "label" : "Low battery"
        }
      },
