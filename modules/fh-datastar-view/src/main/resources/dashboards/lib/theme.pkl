/// The dashboard theme CONTRACT — just the [[Theme]] class. Implementations
/// live in sibling modules, one per look:
///
///   - `theme-beer.pkl` — BeerCSS Material Design 3, the DEFAULT (wired in
///     `entry.pkl`) and currently the only shipped implementation.
///
/// A new theme is a sibling module exporting a `theme: Theme` instance; an
/// entry overrides its look by assigning `theme`, e.g.
/// `theme = (import "lib/theme-mine.pkl").theme`, and can retune any theme by
/// amending the instance (`tokens`/`styles` are ordinary properties; see the
/// implementation modules for their amend forms).
///
/// Everything visual lives in a theme, NOT in the server. The renderer emits
/// `tokens` as `:root` custom properties (with `tokensDark` under
/// prefers-color-scheme:dark); the server `<link>`s `stylesheets`, injects
/// `scripts` as ES modules, and inlines `styles`.
///
/// Contract with the components/renderer (the class names they emit):
///   containers -> `.fh-grid` / `.fh-row` / `.fh-col`, the universal node
///   wrapper (the id'd flex/grid item the renderer puts around EVERY card) ->
///   `.fh-cell`, a dynamic group's member-flow container -> `.fh-group`,
///   per-cell layout classes -> `.fh-cols-<1..12>`/`.fh-cols-full` (authored
///   via the HA-style builders `columns(n)`/`fullWidth()` on
///   components.pkl [[LayoutNode]]), a grid's group-centering opt-out ->
///   the `.fh-start` marker on the grid element (`Grid.centered(false)`),
///   cards -> `.card`, section titles -> `.section`, state text -> `.state`,
///   popup dialog -> `.popup`/`.popup-close`, tabs -> `.tabs`/`.tabbar`/`.tab`.
///
/// The `fh-` LAYOUT classes have ready-made framework-agnostic CSS below
/// ([[layoutCss]]): a theme normally interpolates it at the top of its
/// `styles` (`\(themeMod.layoutCss)`) and only re-implements it to change the
/// layout system itself. The visual classes (`.card`, `.section`, …) are the
/// part each theme styles its own way.
///
/// WRITING A THEME (the whole API surface):
///   1. Create a sibling `theme-<name>.pkl` exporting `theme: Theme` (or an
///      `open class` extending [[Theme]] if you want amendable knobs, like
///      theme-beer's palettes).
///   2. `tokens`/`tokensDark`: HA-named design tokens (see tokens.pkl) —
///      emitted as `:root` custom properties, dark under
///      prefers-color-scheme.
///   3. `stylesheets`/`scripts`: your framework's CDN links (pinned versions,
///      never `@latest`). Scripts are ES modules injected after stylesheets;
///      dashboard BEHAVIOR stays with Datastar — ship JS only for visuals
///      your CSS needs (e.g. BeerCSS's slider track fill), and verify its
///      bindings survive SSE morphs (delegated/document-level listeners do).
///   4. `styles`: start with `\(themeMod.layoutCss)` (the layout contract),
///      then style the visual classes from the roster above on top of the
///      tokens.
///   5. `chrome`: the page frame — MUST wrap `{{{body}}}` in an element with
///      `id="dashboard"` (the navigate/reload swap target; enforced by
///      Dashboard.validate) and, if the dashboard uses popups, host a
///      `<div id="popups"></div>` overlay mount.
///   6. An entry opts in with `theme = (import "lib/theme-<name>.pkl").theme`.
module theme

/// Framework-agnostic CSS for the `fh-` layout contract — the sane default
/// every theme can reuse. Three container behaviors, mirroring HA's
/// "sections" dashboard (see ADR 0008):
///
///   - GRID (`.fh-grid`, the default top-level container + dynamic-group
///     `.fh-group`): a 12-column sizing system where a cell's width is its
///     `columns(n)` span (default 4 — a third, HA's default card size) of 12.
///     Built on flexbox rather than CSS grid so a PARTIAL row (cells not
///     summing to 12) group-centers while a FULL row fills edge-to-edge — the
///     HA-sections feel. Centering is ON by default; `Grid.centered(false)`
///     emits `.fh-start` to left-pack instead. The span basis
///     `(100% + gap) * n/12 - gap` makes any set of spans summing to 12 fit
///     one row exactly (the `+gap`/`-gap` cancels the inter-cell gaps).
///   - ROW (`.fh-row`): a horizontal flex line whose children SHARE the width
///     equally (`flex:1 1 0`). No 12-col spans here — sizing is share-based.
///   - COLUMN (`.fh-col`): a vertical flex stack whose children FILL the width.
///
/// So `columns(n)`/`fullWidth()` are GRID-ONLY affordances; inside a row/column
/// you don't size children, they share/fill. Rows and columns nest freely into
/// each other and into grid cells. On narrow screens (<=640px) every grid cell
/// collapses to full width. The default-span selectors use `:where()` so any
/// authored `.fh-cols-<n>` beats them; `--fh-gap` retunes spacing per theme.
const layoutCss: String = """
  .fh-grid,.fh-group{display:flex;flex-wrap:wrap;justify-content:center;gap:var(--fh-gap,1rem)}
  .fh-grid.fh-start,.fh-group.fh-start{justify-content:flex-start}
  .fh-grid>:where(.fh-cell),.fh-group>:where(.fh-cell){flex:0 1 calc((100% + var(--fh-gap,1rem)) * 4 / 12 - var(--fh-gap,1rem));min-width:0}
  """ + colSpans + """

  .fh-cols-full{flex-basis:100%}
  .fh-row{display:flex;gap:var(--fh-gap,1rem);flex-wrap:wrap}
  .fh-row>.fh-cell{flex:1 1 0;min-width:0;align-self:flex-start}
  .fh-col{display:flex;flex-direction:column;gap:var(--fh-gap,1rem)}
  .fh-col>.fh-cell{width:100%}
  @media (max-width:640px){.fh-grid>.fh-cell,.fh-group>.fh-cell{flex-basis:100%}}
  """

// One span rule per grid column count (`.fh-cols-1` .. `.fh-cols-12`): the
// flex-basis that makes an n/12 cell fit (gaps cancel — see [[layoutCss]]).
const local colSpans: String = new Listing {
  for (n in IntSeq(1, 12)) {
    ".fh-cols-\(n){flex-basis:calc((100% + var(--fh-gap,1rem)) * \(n) / 12 - var(--fh-gap,1rem))}"
  }
}.toList().join("\n")

open class Theme {
  tokens: Mapping<String, String>
  tokensDark: Mapping<String, String>
  stylesheets: Listing<String>
  /// External JS URLs, `<script type="module" src>`-injected in the document
  /// head (after the stylesheets, before Datastar). ES modules — deferred, so
  /// they run after the first paint. For framework helpers a theme's CSS needs
  /// (e.g. BeerCSS's slider fill); dashboard behavior stays Datastar's.
  scripts: Listing<String> = new {}
  styles: String
  chrome: String
}
