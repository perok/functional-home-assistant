/// Dashboard components for the Pkl authoring track — the typed counterpart
/// of `components.libsonnet` (MVP subset: containers, sectionTitle,
/// entityCard, button, slider; see ADR 0006 for what is deferred).
///
/// Cards are CLASSES ("class-as-builder"): the `hidden` properties are the
/// typed authoring surface, and each class derives the backend contract from
/// them — `{kind: "component", card, slots, children}` nodes, where a slot is
/// either a bare string (a constant literal) or a [[Slot]] object (a live
/// JSONata transform). Hidden properties never render, so the emitted JSON is
/// exactly what `Dashboard` decodes.
///
/// CONTRACT: literal slots must be JSON strings, never numbers — the backend
/// slot decoder rejects numbers (stringify numeric config: `"\(...)"`).
module components

import "hass.pkl"
import "pkl:reflect"

// ---- backend output shapes (mirror fh.view.model) ----

/// The object form of a slot (fh.view.model.SlotSource). A live JSONata
/// expression over the card's entity; `reactive = false` marks an
/// identity-derived slot (resolved once, never re-rendered on state change).
class Slot {
  entityId: String? = null
  transform: String = "$state"
  default: String? = null
  bypassUnavailable: Boolean = true
  reactive: Boolean = true
}

/// The common supertype of every layout-tree node. `kind` is the circe
/// discriminator: `"component"` for a [[Node]], `"dynamic"` for a
/// [[DynamicGroup]].
abstract class LayoutNode {
  kind: String
}

abstract class Node extends LayoutNode {
  kind: "component" = "component"
  card: String
  // The card's template + declared slots, CO-LOCATED with the class that
  // populates them. `hidden`, so it never emits into a node's JSON — the
  // [[cards]] registry at the bottom collects each concrete subclass's
  // class-level default by reflection. Must be a self-contained default (no
  // instance-property references). NOTE (multiline templates): each HTML
  // *attribute value* must stay on one physical line — line breaks between
  // tags/attributes are harmless whitespace, but a newline inside an
  // attribute would break it.
  hidden cardDef: CardDef
  slots: Mapping<String, Slot|String> = new {}
  // Widened to LayoutNode so a container can nest either a component or a
  // dynamic group.
  children: Listing<LayoutNode> = new {}
  // A node-level map of inline surfaces the build-phase hoist lifts into the
  // top-level `surfaces` registry (keyed `<node-id>_<localKey>`), splicing the
  // node's real id into every [[NODE_ID]] token in the subtree. Null (dropped
  // from JSON by omitNullProperties) unless a tap composes an inline popup.
  inlineSurfaces: Mapping<String, SurfaceDef>? = null
}

class CardDef {
  template: String
  slots: Listing<String> = new {}
}

/// An on-demand render subtree the build-phase hoist lifts into the top-level
/// `surfaces` registry (mirrors fh.view.model.Surface). Registered surfaces are
/// authored directly (a top-level `surfaces` mapping); inline surfaces ride on a
/// node's [[Node.inlineSurfaces]] and are hoisted, keyed `<node-id>_<localKey>`.
/// `bakeInto`/`bakeAs`/`bakeIndex`/`defaultOpen` drive first-paint baking (tabs
/// — step 5); a plain popup leaves them null. `defaultOpen` is a nullable
/// Boolean so omitNullProperties drops it and the decoder defaults it to false.
open class SurfaceDef {
  content: LayoutNode
  bakeInto: String? = null
  bakeAs: String? = null
  bakeIndex: Int? = null
  defaultOpen: Boolean? = null
}

/// A REGISTERED popup surface: the `body` cards are wrapped in the [[Popup]]
/// dialog automatically (registered popup surfaces must carry their own wrap —
/// ADR 0002). `lib/entry.pkl` makes this the `surfaces` mapping default, so an
/// entry amends a popup surface into existence with no `new` and no wrap:
///   surfaces { ["detail"] { body { c.title("...") c.entityCard(e) } } }
/// A non-popup surface is still an explicit assignment:
///   ["x"] = new c.SurfaceDef { content = ... }
class PopupSurface extends SurfaceDef {
  hidden body: Listing<LayoutNode> = new {}
  content = new Popup { children = body }
}

// ---- author-facing descriptors ----

/// A live value expression for a display field that also accepts a plain
/// string: `label = expr(#"$attr.friendly_name & " " & $state"#)` vs the
/// literal `label = "Kitchen"`.
class Expr {
  entityId: String? = null
  transform: String
}

function expr(s: String): Expr = new { transform = s }

/// A live value expression bound to an EXPLICIT entity (a cross-entity read):
/// the emitted slot names its own `entityId` instead of inheriting the card's.
/// Mirrors jsonnet `entityOf` (components.libsonnet:102-105).
function exprOf(eo: hass.Entity, s: String): Expr = new { entityId = eo.entity_id; transform = s }

/// A tap descriptor: the whole Datastar click expression, either live (a Slot
/// reading $entity_id/$domain) or a constant string (navigate). A tap that opens
/// an INLINE popup also carries `inlineSurfaces` (the dialog content); the card
/// copies it onto the node so the hoist can lift it.
class Tap {
  onclick: Slot|String
  inlineSurfaces: Mapping<String, SurfaceDef>? = null
}

// The placeholder a node uses to refer to its own backend-minted id — the SAME
// id the renderer injects as `{{id}}`. The build-phase hoist
// (DashboardBuild.hoistInlineSurfaces / NodeIdToken) splices the real id in.
// MUST equal DashboardBuild.NodeIdToken. Authors never type it — the
// `openPopupInline` tap embeds it (paired with an `inlineSurfaces` marker under
// the matching local key).
const NODE_ID: String = "@@NODE_ID@@"

// The default service route (domain/service) for a tap, resolved per entity
// at runtime ($domain). Scenes/scripts turn_on, buttons press, everything
// else homeassistant/toggle — same JSONata as components.libsonnet.
const local defaultRoute =
  #"($a := $lookup({"scene": "scene/turn_on", "script": "script/turn_on", "button": "button/press", "input_button": "input_button/press"}, $domain); $a ? $a : "homeassistant/toggle")"#

// Wrap a JSONata route expression into the full Datastar click expression
//   @post('/sse/action/<domain>/<service>/<entity_id>')
const local function serviceOnclick(route: String): String =
  #""@post('/sse/action/" & ("# + route + #") & "/" & $entity_id & "')""#

// A click expression is identity-derived: it inherits the card's entity to
// resolve $entity_id/$domain, but never varies with state (reactive = false)
// and must resolve even when the entity is unavailable.
const local function clickSlot(transformExpr: String): Slot = new {
  transform = transformExpr
  reactive = false
  bypassUnavailable = false
}

/// Service call resolved from the entity's domain (the default tap).
const toggleTap: Tap = new { onclick = clickSlot(serviceOnclick(defaultRoute)) }

/// Explicit "<domain>/<service>" override, e.g. serviceTap("lock/lock").
function serviceTap(action: String): Tap =
  new { onclick = clickSlot(serviceOnclick("\"" + action + "\"")) }

/// In-place swap to dashboard `slug` (+ URL via pushState) — a constant click.
function navigate(slug: String): Tap =
  new { onclick = "@post('/sse/navigate/\(slug)'); history.pushState(null,'','/d/\(slug)')" }

/// Dismiss the (single, at-a-time) open popup — the id-less `POST
/// /sse/popup/close`. Drop a button carrying this inside a popup's content.
function closePopup(): Tap = new { onclick = "@post('/sse/popup/close')" }

/// Open the surface REGISTERED under `surfaceId` (a top-level `surfaces` entry).
/// A registered popup surface is [[Popup]]-wrapped (the `<dialog>`); the backend
/// renders it bare into the `#popups` mount.
function openPopup(surfaceId: String): Tap =
  new { onclick = "@post('/sse/surface/open/\(surfaceId)')" }

/// Open an INLINE popup: `content` is wrapped in a [[Popup]] dialog and stashed
/// under this node's `inlineSurfaces["self"]`; the onclick references the future
/// surface id (`<NODE_ID>_self`) the hoist mints and splices. (Pkl can't
/// union-dispatch string|node in one function like jsonnet's `openPopup`, so the
/// registered and inline forms are two named functions — a deliberate API
/// deviation, see ADR 0006.)
// The parameter is `body`, NOT `content`: a bare `content` inside the nested
// `new SurfaceDef { content = new Popup { children { <here> } } }` amend would
// bind to SurfaceDef's own `content` member (a self-reference → stack overflow),
// per the Pkl amend-scoping gotcha.
function openPopupInline(body: Node): Tap = new {
  onclick = "@post('/sse/surface/open/\(NODE_ID)_self')"
  inlineSurfaces = new Mapping {
    ["self"] = new SurfaceDef { content = new Popup { children { body } } }
  }
}

// ---- shared slot builders (port of labelSlot/valueSlot/secondarySlot) ----

// Auto-appended unit for a value display: the entity's unit_of_measurement,
// space-separated, when it has one.
const local UNIT =
  #" & ($attr.unit_of_measurement ? " " & $attr.unit_of_measurement : "")"#

// label: Expr -> live (still resolving when unavailable, so a label shows the
// name, not "unavailable"); String -> literal; null -> the entity's
// friendly_name (falling back to its id) baked as a literal.
const local function labelSlot(entity: hass.Entity?, label: (String|Expr)?): Slot|String =
  if (label is Expr) new Slot { entityId = label.entityId; transform = label.transform; bypassUnavailable = false }
  else if (label != null) label
  // Dynamic default: a LIVE friendly_name (falling back to entity_id),
  // inheriting the matched entity — mirrors components.libsonnet:78-80.
  else if (entity != null && entity.isDynamic) new Slot { transform = "$attr.friendly_name ? $attr.friendly_name : $entity_id"; bypassUnavailable = false }
  else if (entity != null) entity.friendly_name ?? entity.entity_id
  else ""

// value: null -> $state (+ unit); String -> that attribute (+ unit);
// Expr -> your expression verbatim (you own the unit).
const local function valueSlot(value: (String|Expr)?): Slot =
  if (value is Expr) new Slot { entityId = value.entityId; transform = value.transform }
  else new Slot {
    transform = (if (value == null) "$state" else "$attr." + value) + UNIT
  }

// secondary (only built when authored): String -> an attribute (no unit);
// Expr -> live. Empty default keeps the mustache section collapsed when blank.
const local function secondarySlot(secondary: String|Expr): Slot =
  new Slot {
    entityId = if (secondary is Expr) secondary.entityId else null
    transform = if (secondary is Expr) secondary.transform else "$attr." + secondary
    default = ""
  }

// ---- the components ----

// `cssClass` is the authoring name (`class` is a Pkl reserved word); it emits
// the literal slot key `"class"` that the `{{#class}}` template sections read.
class Row extends Node {
  card = "fhrow"
  cardDef = new CardDef {
    template = """
      <div class="fh-row{{#class}} {{class}}{{/class}}">{{#children}}{{{html}}}{{/children}}</div>
      """
  }
  hidden cssClass: String? = null
  slots {
    when (cssClass != null) {
      ["class"] = cssClass!!
    }
  }
}

/// Amendable base instance — `(c.row) { children { ... } }`. The parens are
/// MANDATORY: Pkl requires them around ANY amend parent that isn't a `new`
/// expression (qualified reads, method calls, even bare in-scope names).
/// There is no comma-free call form: function arguments are always
/// comma-separated, and a typed-object amend body accepts only PROPERTIES
/// (bare elements/entries need a Listing/Mapping parent — hence `children`).
hidden row: Row = new Row {}

class Column extends Node {
  card = "fhcol"
  cardDef = new CardDef {
    template = """
      <div class="fh-col{{#class}} {{class}}{{/class}}">{{#children}}{{{html}}}{{/children}}</div>
      """
  }
  hidden cssClass: String? = null
  slots {
    when (cssClass != null) {
      ["class"] = cssClass!!
    }
  }
}
/// Amendable base instance — `(c.column) { children { ... } }` (see [[row]]).
hidden column: Column = new Column {}

/// Static title text (not bound to an entity).
class SectionTitle extends Node {
  card = "sectionTitle"
  cardDef = new CardDef {
    template = """
      <h2 class="section">{{label}}</h2>
      """
    slots { "label" }
  }
  hidden text: String
  slots {
    ["label"] = text
  }
}

/// Default entity icon per domain — Material Symbols names (the font ships
/// with the BeerCSS theme; a theme without an icon font hides `header i`, see
/// theme-pico.pkl). Resolved at RUNTIME via `$lookup($domain)` (the slider
/// config's identity-slot mechanism), so dynamic-group ($self) cards get the
/// matched entity's icon too; an unlisted domain yields "" and the template
/// section renders nothing.
const local domainIcons: Mapping<String, String> = new {
  ["light"] = "lightbulb"
  ["switch"] = "toggle_on"
  ["input_boolean"] = "toggle_on"
  ["sensor"] = "sensors"
  ["binary_sensor"] = "sensors"
  ["lock"] = "lock"
  ["cover"] = "blinds"
  ["climate"] = "thermostat"
  ["fan"] = "mode_fan"
  ["media_player"] = "speaker"
  ["camera"] = "videocam"
  ["person"] = "person"
  ["scene"] = "palette"
  ["script"] = "description"
  ["automation"] = "smart_toy"
  ["vacuum"] = "vacuum"
  ["weather"] = "partly_cloudy_day"
  ["button"] = "radio_button_checked"
}
const local iconLookup: String =
  "$lookup({" + (new Listing {
    for (d, i in domainIcons) {
      "\"\(d)\":\"\(i)\""
    }
  }).toList().join(",") + "}, $domain)"

/// HA-like entity card: domain icon + label + value (state or attribute, unit
/// auto-appended) + optional secondary line + optional tap. `icon` overrides
/// the domain default with a literal Material Symbols name.
class EntityCard extends Node {
  card = "entityCard"
  cardDef = new CardDef {
    template = """
      <article class="card entity{{#tappable}} tappable{{/tappable}}"{{#tappable}}
        data-on:click="{{{onclick}}}"{{/tappable}}>
        <header>{{#icon}}<i>{{icon}}</i>{{/icon}}{{label}}</header>
        <span class="state">{{value}}</span>{{#secondary}}
        <span class="secondary">{{secondary}}</span>{{/secondary}}
      </article>
      """
    slots { "label"; "value"; "entity_id" }
  }
  hidden entity: hass.Entity
  hidden label: (String|Expr)? = null
  hidden value: (String|Expr)? = null
  hidden secondary: (String|Expr)? = null
  hidden icon: String? = null
  hidden tap: Tap? = null
  // Copy the tap's inline surfaces onto the node so the hoist lifts them
  // (mirror jsonnet tapInline, components.libsonnet:186-188). Null when the tap
  // is null or carries no inline popup → dropped by omitNullProperties.
  inlineSurfaces = if (tap != null) tap!!.inlineSurfaces else null
  slots {
    // entity_id is the card's subject — the magical slot the others inherit.
    ["entity_id"] = entity.entity_id
    ["label"] = labelSlot(entity, label)
    ["value"] = valueSlot(value)
    // Author literal, else the runtime domain lookup. Identity-derived
    // (reactive = false); bypass OFF so an unavailable entity still resolves
    // its icon from $domain rather than leaking raw state into the slot.
    ["icon"] =
      if (icon != null) icon!!
      else new Slot { transform = iconLookup; reactive = false; bypassUnavailable = false }
    when (secondary != null) {
      ["secondary"] = secondarySlot(secondary!!)
    }
    when (tap != null) {
      ["tappable"] = "1"
      ["onclick"] = tap!!.onclick
    }
  }
}

/// Static entity card as a call (amend options in parens).
function entityCard(e: hass.Entity): EntityCard = new EntityCard { entity = e }
/// The SAME constructor as a VALUE, for [[DynamicGroup]] render positions:
/// `branches { [domainIs("light")] = c.entityCard }`. Methods and function-value
/// properties are separate namespaces, so this delegate co-exists with the method
/// above — the parens in `entityCard(e)` pick the method (no recursion). The
/// factory param is `e`, NOT `entity`: a param named after the property it sets
/// self-references inside the amend (the amend-scoping gotcha).
hidden entityCard: (hass.Entity) -> EntityCard = (e) -> entityCard(e)

/// Generic click button (service call or navigate). `action = null` defaults
/// to the domain-resolved service call, which needs an entity. (Tab-bar
/// entries are NOT buttons — see [[TabButton]].)
class Button extends Node {
  card = "button"
  cardDef = new CardDef {
    template = """
      <button class="card" data-on:click="{{{onclick}}}">{{label}}</button>
      """
    slots { "label"; "onclick" }
  }
  hidden entity: hass.Entity? = null
  hidden label: (String|Expr)? = null
  hidden action: Tap? = null
  // Copy the action's inline surfaces onto the node (mirror jsonnet tapInline).
  inlineSurfaces = if (action != null) action!!.inlineSurfaces else null
  slots {
    when (entity != null) {
      ["entity_id"] = entity!!.entity_id
    }
    ["label"] = labelSlot(entity, label)
    ["onclick"] = (action ?? toggleTap).onclick
  }
}

/// One tab in the [[Tabs]] bar — BeerCSS's NATIVE tab markup (`.tabs > a`
/// anchors), so the MD3 tab look (underline active indicator, hover/press
/// states, even distribution) comes from the framework, not hand-rolled CSS.
/// Built by [[Tabs]] internally; not an authoring surface. `active` is the
/// Datastar boolean expression driving the `.active` class client-side
/// (`data-class`); `onclick` opens the tab's hoisted surface, seeds the
/// signal, and writes the restore cookie.
class TabButton extends Node {
  card = "tab"
  cardDef = new CardDef {
    template = #"<a data-on:click="{{{onclick}}}" data-class="{active: {{{active}}}}">{{label}}</a>"#
    slots { "label"; "onclick"; "active" }
  }
  hidden label: String
  hidden onclick: String
  hidden active: String
  slots {
    ["label"] = label
    ["onclick"] = onclick
    ["active"] = active
  }
}

/// POPUP dialog container — a NORMAL container card (like [[Row]]/[[Column]])
/// that wraps a popup surface's content in the overlay `<dialog>` + a ✕ posting
/// the id-less close. Composed INTO a surface's content, NOT applied as backend
/// chrome. Authors rarely touch it directly: [[openPopupInline]] wraps its body
/// in one, and a registered surface gets it via the [[PopupSurface]] default.
class Popup extends Node {
  card = "popup"
  // `open` is static markup (a `<dialog>` without it is display:none); the
  // dialog is transient — present only while open. The ✕ posts the id-less
  // close. Ported verbatim from components.libsonnet:511.
  cardDef = new CardDef {
    template = #"<dialog open class="popup"><button class="popup-close" data-on:click="@post('/sse/popup/close')">✕</button>{{#children}}{{{html}}}{{/children}}</dialog>"#
  }
}
/// Amendable base instance — `(c.popup) { children { ... } }` (see [[row]]).
hidden popup: Popup = new Popup {}

/// A tab bar over ONE inline panel — one tab visible at a time. Pure
/// composition (mirror jsonnet `tabs`, components.libsonnet:467-499): each tab's
/// cards become an inline surface baked into this component's panel host
/// (`bakeInto = NODE_ID`, `bakeAs = "panel"`), sharing one exclusivity group;
/// the bar buttons open them, seed the active-tab signal, and persist the active
/// index to the `fhui_<id>` cookie the server reads on the GET so reload /
/// navigate restore the tab flash-free. The first tab is `defaultOpen` (baked on
/// first paint) — emitted `null` for the rest so omitNullProperties drops it and
/// the decoder defaults `false`, matching jsonnet byte-for-byte.
class Tabs extends Node {
  card = "tabs"
  // The bar is BeerCSS's `.tabs` element (its children are [[TabButton]]
  // anchors); the panel host + `{{{panel}}}` hole live below it.
  // `data-signals` seeds the active-tab signal to the baked tab's index
  // (`{{bakeIndex}}`, injected by the renderer).
  cardDef = new CardDef {
    template = """
      <div class="fh-col">
        <div class="tabs">
          {{#children}}{{{html}}}{{/children}}
        </div>
        <div id="{{id}}_panel" class="tab-panel" data-signals="{ tab_{{id}}: {{bakeIndex}} }">
          {{{panel}}}
        </div>
      </div>
      """
  }
  /// label -> that tab's cards. Bar order = insertion order (Mapping preserves
  /// it). The Listing DEFAULT lets a tab amend into existence and add cards
  /// directly — no `new`, no `children`:
  ///   (c.tabs) { tabs { ["Lights"] { c.entityCard(e) c.slider(l) } } }
  /// Each tab's cards are wrapped in a [[Row]] panel; a tab wanting a different
  /// container nests it as the single card: `["X"] { new Column { ... } }`.
  hidden tabs: Mapping<String, Listing<LayoutNode>> = new { default = (_) -> new Listing {} }
  // Insertion-ordered labels; the derivations below need the tab INDEX (surface
  // keys, bakeIndex, the signal seed), which a Mapping generator lacks — a List
  // generator yields (index, element).
  hidden labels: List<String> = tabs.keys.toList()
  // Each tab's cards hoisted into a Row-wrapped panel surface.
  inlineSurfaces = new Mapping {
    for (i, l in labels) {
      ["t\(i)"] = new SurfaceDef {
        content = new Row { children = tabs[l] }
        bakeInto = NODE_ID
        bakeAs = "panel"
        bakeIndex = i
        defaultOpen = if (i == 0) true else null
      }
    }
  }
  // The `.tabs` bar anchors: each opens its tab's surface (`<id>_t<i>`), sets
  // the active-tab signal, and writes the restore cookie. `$` is a literal
  // Datastar signal sigil (Pkl only interpolates `\(...)`); the exact onclick
  // text is asserted in the tests.
  children = new Listing {
    for (i, l in labels) {
      new TabButton {
        label = l
        active = "$tab_\(NODE_ID) == \(i)"
        onclick = "@post('/sse/surface/open/\(NODE_ID)_t\(i)'); $tab_\(NODE_ID) = \(i); document.cookie = 'fhui_\(NODE_ID)=\(i);path=/;max-age=31536000;samesite=lax'"
      }
    }
  }
}

/// Amendable base instance — `(c.tabs) { tabs { ["Lights"] { ... } } }`.
hidden tabs: Tabs = new Tabs {}

// The slider's controllable config per domain: the service to call, the
// service_data key the value rides on, the range bounds, and which attribute
// is the live position. Add a domain (cover/fan/climate…) by adding a row —
// TYPED: a missing/misspelled field is a build error. A STATIC slider resolves
// its config AT BUILD TIME from the entity's domain (baked literals); a slider
// bound to [[hass.SELF]] (a dynamic-group case) can't know the domain until a
// match, so it falls back to jsonnet's runtime `$lookup($domain)` over this
// same table (see [[sliderLookup]]).
class SliderSpec {
  action: String
  key: String
  min: Int
  max: Int
  value: String
}

const sliderSpec: Mapping<String, SliderSpec> = new {
  ["light"] = new { action = "light/turn_on"; key = "brightness"; min = 1; max = 255; value = "brightness" }
  ["cover"] = new { action = "cover/set_cover_position"; key = "position"; min = 0; max = 100; value = "current_position" }
  ["fan"] = new { action = "fan/set_percentage"; key = "percentage"; min = 0; max = 100; value = "percentage" }
}

// A JSONata object literal `{"<domain>": <spec.field>}` over the sliderSpec
// table — `{"light":"light/turn_on","cover":...}` (JSONata object syntax IS
// JSON). Pkl has no reflect-by-string, so the field is a lambda accessor;
// String values are quoted, Int (min/max) values emitted bare. Mirrors jsonnet
// sliderDomainMap (components.libsonnet:225-229) but over all three domains.
const local function sliderDomainMap(get: (SliderSpec) -> Any): String =
  "{" + (new Listing {
    for (d, s in sliderSpec) {
      let (v = get.apply(s))
        "\"\(d)\":" + (if (v is String) "\"\(v)\"" else "\(v)")
    }
  }).toList().join(",") + "}"

// `$lookup(<map>, $domain)` — resolve a config field from the entity's domain
// at runtime (components.libsonnet:231).
const local function sliderLookup(get: (SliderSpec) -> Any): String =
  "$lookup(" + sliderDomainMap(get) + ", $domain)"

// The live position: read the domain's position attribute off $attr
// (components.libsonnet:233).
const local sliderValueLookup: String = "$lookup($attr, " + sliderLookup((s) -> s.value) + ")"

// A slider config slot (action/key/min/max): author override → build-time spec
// literal (stringified — the backend slot decoder rejects numbers) → the
// runtime `$lookup($domain)` fallback for a spec-less ($self) slider. The
// lookup form is identity-derived (reactive = false, never a live dependency)
// and resolves even when the entity is unavailable (components.libsonnet:237).
// `override` is a Pkl reserved word — the param is `ovr`.
const local function sliderConfig(ovr: String?, spec: SliderSpec?, get: (SliderSpec) -> Any): Slot|String =
  if (ovr != null) ovr
  else if (spec != null) "\(get.apply(spec!!))"
  else new Slot { transform = sliderLookup(get); reactive = false; bypassUnavailable = false }

/// Value slider. Accepts either a static entity whose domain has a sliderSpec
/// row (config baked at build time) or [[hass.SELF]] inside a dynamic case
/// (config resolved per matched entity via runtime `$lookup($domain)`). A
/// slider on e.g. a static sensor is a BUILD error naming the dashboard line.
class Slider extends Node {
  card = "slider"
  // The range input rides inside BeerCSS's slider markup (`.slider` wrapper +
  // trailing `<span>` = the painted MD3 track, `max` = full card width; NO
  // `.tooltip` — its value text bled through behind the track, and the live
  // value already shows in the head line). The FILL is backend-rendered:
  // the template bakes `--_start`/`--_end` as an inline style from the `fill`
  // slot, because BeerCSS's own fill is an inline style its JS writes on
  // `input` events — a Datastar morph wipes it and (the vars defaulting to
  // 0%) the track snaps to fully-filled. Baking it makes every morph correct
  // by construction; beer.min.js still repaints live DURING a drag. The label
  // line is a `.slider-head` class contract (both themes style it) — NOT a
  // `<header>` (BeerCSS styles header as a 4rem app-bar grid, which swallowed
  // the text) and NOT BeerCSS `.row`/`.max` (inline-size:100% squeezes the
  // state span into per-character wrapping).
  cardDef = new CardDef {
    template = """
      <article class="card">
        <div class="slider-head"><strong>{{label}}</strong><span class="state">{{state}}</span></div>
        <div class="slider max" style="--_start: 0%;--_end: {{fill}}%">
          <input type="range" min="{{min}}" max="{{max}}"
            data-signals="{ val_{{id}}: {{value}} }"
            data-bind="val_{{id}}"
            data-on:change="@post('/sse/action/{{{action}}}/{{{entity_id}}}/{{key}}/' + $val_{{id}})" />
          <span></span>
        </div>
      </article>
      """
    slots { "label"; "state"; "value"; "action"; "min"; "max"; "key"; "entity_id" }
  }
  hidden entity: hass.Entity(isDynamic || sliderSpec.containsKey(domain))
  hidden label: (String|Expr)? = null
  hidden action: String? = null // per-instance overrides of the domain default
  hidden key: String? = null
  hidden min: Int? = null
  hidden max: Int? = null
  // Null for a dynamic ($self) slider — the domain is unknown until a match, so
  // config falls through sliderConfig to the runtime lookup tier.
  hidden spec: SliderSpec? = if (entity.isDynamic) null else sliderSpec[entity.domain]
  // The JSONata pieces of the `fill` computation, honouring the same three
  // config tiers as the input's own slots: author override → build-time spec
  // literal → runtime $lookup($domain).
  hidden valueExpr: String =
    if (spec != null) "$attr." + spec!!.value else sliderValueLookup
  hidden minExpr: String =
    if (min != null) "\(min!!)"
    else if (spec != null) "\(spec!!.min)"
    else sliderLookup((s) -> s.min)
  hidden maxExpr: String =
    if (max != null) "\(max!!)"
    else if (spec != null) "\(spec!!.max)"
    else sliderLookup((s) -> s.max)
  slots {
    ["entity_id"] = entity.entity_id
    ["label"] = labelSlot(entity, label)
    // The display header (inherits entity_id, bypassUnavailable default).
    ["state"] = new Slot {}
    // The range input's numeric position: opt OUT of bypass so an unavailable
    // entity falls back to `default` ("0") rather than "unavailable". Static:
    // read the domain's position attr; dynamic: $lookup it per match.
    ["value"] = new Slot {
      transform = valueExpr
      default = "0"
      bypassUnavailable = false
    }
    // The track fill, as the `--_end` percentage (distance from the RIGHT
    // edge, per BeerCSS's span/clip-path convention): 100 - value% of the
    // min..max range. Null-guarded — an absent position attribute (light off)
    // means an empty fill (end = 100), not a JSONata type error.
    ["fill"] = new Slot {
      transform = "($v := \(valueExpr); $v != null ? $round(100 - (($v - \(minExpr)) * 100 / (\(maxExpr) - \(minExpr)))) : 100)"
      default = "100"
      bypassUnavailable = false
    }
    ["action"] = sliderConfig(action, spec, (s) -> s.action)
    ["key"] = sliderConfig(key, spec, (s) -> s.key)
    ["min"] = sliderConfig(if (min != null) "\(min)" else null, spec, (s) -> s.min)
    ["max"] = sliderConfig(if (max != null) "\(max)" else null, spec, (s) -> s.max)
  }
}

/// Value slider as a call (see [[Slider]] for the domain contract).
function slider(e: hass.Entity): Slider = new Slider { entity = e }
/// The slider constructor as a VALUE, for [[DynamicGroup]] render positions.
hidden slider: (hass.Entity) -> Slider = (e) -> slider(e)

// ---- call-style card factories (methods construct; `|>` adds) ----
// Entity-first construction as a CALL, options via a PARENTHESIZED amend:
//   (c.entityCard(dump.entities.x)) { tap = c.toggleTap; label = "Office" }
// (the outer parens are mandatory — `c.entityCard(x) { ... }` is a parse error).
// The trivial card collapses to a bare call `c.entityCard(x)`; `new c.X { ... }`
// stays fully supported (same classes). `|>` is reserved for ADDITIONS (mixins),
// never construction — methods aren't first-class, so there is no `x |> entityCard`.

/// The common toggle-on-tap addition: `c.entityCard(x) |> c.tappable`.
tappable: Mixin<EntityCard> = new { tap = toggleTap }

/// Static title text as a call: `c.title("Active now")`.
function title(t: String): SectionTitle = new SectionTitle { text = t }
/// A service/navigate button as a call: `c.button("Close", c.closePopup())`.
function button(l: String, a: Tap): Button = new Button { label = l; action = a }

// ---- floor/area composition (typed-dump driven) ----

/// One section per area of `floor` that HAS lights: the area name as a
/// [[SectionTitle]] followed by a [[Slider]] per light, each area wrapped in its
/// own column. The typed counterpart of `overetasje.jsonnet`'s `areaView`,
/// driven by the generated dump's `Floor.areas` / `Area.lights` member lists
/// (both `hidden` on [[hass.Floor]]/[[hass.Area]] — readable, never rendered).
/// Areas with no lights are skipped, so the result is exactly the light-bearing
/// sections. Returns a [[Column]] so it drops straight into an entry's tree.
function floorView(floor: hass.Floor): Column = new Column {
  children {
    for (area in floor.areas) {
      when (!area.lights.isEmpty) {
        new Column {
          children {
            title(area.area_name)
            for (light in area.lights) {
              slider(light)
            }
          }
        }
      }
    }
  }
}

// ---- dynamic groups (the Predicate AST + Mapping-branch DSL) ----
// A dynamic group renders one card PER live entity matching a `query`,
// optionally dispatching the card per entity. The matched entity's
// id/entity_id/label are auto-injected and every inheriting slot is rebound to
// it (Renderer.renderCase) — so a case is built with the SAME leaf classes as a
// static card, just passing `hass.SELF` as the entity. `hass.SELF` is an
// INTERNAL sentinel: authors write render lambdas `(e) -> ...` and never see it
// (`caseOf` applies the lambda to it below). Port of components.libsonnet:579-661.

/// A property-query comparison operator. TYPED — a misspelled op is now a build
/// error (the backend `Op` decoder is case-insensitive over exactly these).
typealias PredicateOp = "eq"|"ne"|"lt"|"lte"|"gt"|"gte"

/// The runtime property-query AST. `kind` is the circe discriminator.
/// Combinators are METHODS (methods never render, so no `hidden` needed):
/// `domainIs("light").and(stateIs("on"))`, `.or(...)`, `.not()`. `and`/`or`/`not`
/// are legal method names — the Pkl operators are `&&`/`||`/`!`, so no collision.
abstract class Predicate {
  kind: String
  /// Matches when BOTH this and `other` match.
  function and(other: Predicate): PAnd = let (l = this) new PAnd { items { l; other } }
  /// Matches when EITHER this or `other` matches.
  function or(other: Predicate): POr = let (l = this) new POr { items { l; other } }
  /// Matches when this does NOT. (`let (l = this)`: a bare `this` inside the
  /// `new {}` body rebinds to the freshly-built object, not the receiver.)
  function not(): PNot = let (l = this) new PNot { item = l }
}

/// `property <op> value`. `property` is one of `"domain"`, `"state"`, or
/// `"attr:<name>"`; `value` is Any so a numeric threshold rides as a JSON
/// number (unlike a slot literal, a query value is not stringified).
class Cmp extends Predicate {
  kind: "cmp" = "cmp"
  property: String
  op: PredicateOp
  value: Any
}

class PAnd extends Predicate {
  kind: "and" = "and"
  items: Listing<Predicate>
}

class POr extends Predicate {
  kind: "or" = "or"
  items: Listing<Predicate>
}

class PNot extends Predicate {
  kind: "not" = "not"
  item: Predicate
}

// `const` so [[always]] (referenced from the [[DynamicGroup]] class body) may
// call it. Parameters are NOT named after the properties they set: inside a
// `new { property = property }` amend the RHS binds to the object's own member
// (infinite recursion), so each argument gets a distinct name.
const function cmp(prop: String, cmpOp: PredicateOp, cmpVal: Any): Cmp =
  new { property = prop; op = cmpOp; value = cmpVal }

/// Matches every entity (a domain is never literally this sentinel). `const`
/// because [[DynamicGroup.cases]] references it from the class body.
const always: Cmp = cmp("domain", "ne", "__never__")

/// `domain == d`, e.g. `domainIs("light")`.
function domainIs(d: String): Cmp = cmp("domain", "eq", d)
/// `state == s`, e.g. `stateIs("on")`.
function stateIs(s: String): Cmp = cmp("state", "eq", s)
/// `attr:device_class == dc`, e.g. `deviceClassIs("battery")`.
function deviceClassIs(dc: String): Cmp = cmp("attr:device_class", "eq", dc)
/// `attr:<name> < threshold`, e.g. `attrBelow("battery_level", 20)`.
function attrBelow(name: String, threshold: Any): Cmp = cmp("attr:" + name, "lt", threshold)
/// `state < threshold`.
function stateBelow(threshold: Any): Cmp = cmp("state", "lt", threshold)
// Battery sensors expose the % as their STATE with device_class "battery"
// (non-numeric states like "unavailable" simply don't match `state < x`).
/// Battery sensors under `threshold` percent.
function lowBattery(threshold: Any): PAnd = deviceClassIs("battery").and(stateBelow(threshold))

/// One dispatch branch: a predicate + the card (built against `hass.SELF`) to
/// render when it matches. Keeps the card + its slots but drops the build-time
/// `entity_id` slot (the renderer sets the matched entity as the subject per
/// match) and the unused children.
class Case {
  `when`: Predicate
  card: String
  slots: Mapping<String, Slot|String> = new {}
}

// Build a [[Case]] from a predicate and a render fn: apply the fn to the
// INTERNAL `hass.SELF` placeholder to obtain the card, then keep its card name +
// slots but filter the `entity_id` key out (the renderer injects the matched
// entity per match). `const local` because [[DynamicGroup.cases]] calls it from
// the class body. Cases stay leaf-only today (children dropped), but the
// `(e) -> ...` shape already distributes the entity explicitly, so it needs no
// redesign if the wire format ever grows composite cases.
const local function caseOf(p: Predicate, r: (hass.Entity) -> Node): Case =
  let (node = r.apply(hass.SELF))
    new Case {
      `when` = p
      card = node.card
      slots = new Mapping {
        for (k, v in node.slots) {
          when (k != "entity_id") {
            [k] = v
          }
        }
      }
    }

/// A runtime-resolved group: render one card PER live entity matching `query`.
/// Branches are a `Mapping<Predicate, render fn>` — one line per branch, author
/// order preserved (= first-match dispatch order), a duplicate predicate a build
/// error, and each branch replaceable BY KEY when amending a base group (a
/// Listing amend would be append-only). Each render fn is `(hass.Entity) -> Node`:
/// the author writes exactly where the matched entity flows and never sees the
/// `$self` sentinel. `render` is the fallback for entities no branch matched (and
/// the ONLY card when `branches` is empty).
class DynamicGroup extends LayoutNode {
  kind: "dynamic" = "dynamic"
  query: Predicate
  hidden branches: Mapping<Predicate, (hass.Entity) -> Node> = new {}
  /// The card for entities no branch matched; null when a branch covers them all.
  // TODO rename as else, or no, also just add else and we translate either or to fallback
  hidden render: ((hass.Entity) -> Node)? = null
  cases: Listing<Case>(!isEmpty) = new Listing {
    for (p, r in branches) { caseOf(p, r) }
    when (render != null) { caseOf(always, render!!) }
  }
}

// ---- the backend-facing card library (DERIVED from the card classes) ----
// Each card class carries its own template + declared slots (`cardDef`,
// co-located with the logic; hidden, so it never emits into a node's JSON).
// The registry below assembles `cardName -> CardDef` by reflecting over this
// module's concrete [[Node]] subclasses — registration is automatic: a new
// card is just a class. `reflect.Property.defaultValue` reads the evaluated
// CLASS-LEVEL default, which is why a `cardDef` must be self-contained.

const local nodeClass = reflect.Class(Node)

const local function cardNameOf(clsName: String, cls: reflect.Class): String =
  let (v = cls.properties["card"].defaultValue)
    if (v is String) v
    else throw("card class \(clsName) must default `card` to a literal card name")

const local function cardDefOf(clsName: String, cls: reflect.Class): CardDef =
  let (v = cls.properties["cardDef"].defaultValue)
    if (v is CardDef) v
    else throw("card class \(clsName) must set `cardDef` (its template + declared slots)")

cards: Mapping<String, CardDef> = new {
  for (clsName, cls in reflect.Module(module).classes) {
    when (cls.isSubclassOf(nodeClass) && cls != nodeClass && !cls.modifiers.contains("abstract")) {
      [cardNameOf(clsName, cls)] = cardDefOf(clsName, cls)
    }
  }
}
