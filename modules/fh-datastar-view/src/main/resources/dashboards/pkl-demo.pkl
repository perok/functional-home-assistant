// The Pkl-authored demo dashboard, served at /d/pkl-demo (slug = filename)
// next to the jsonnet dashboards. Exercises the MVP component set: entity
// cards (default value, live expr override, tap), a domain-checked slider,
// and cross-dashboard navigation back to the jsonnet default.
//
// `amends "lib/entry.pkl"` supplies the `cards`/`theme` scaffold; the entry
// sets only `surfaces` + `card`. `lib/dump.pkl` is GENERATED (by PklDump, from
// the live HA registry) when the server or build runs — like `dump.libsonnet`
// on the jsonnet track. (Plain `//` comments here: a doc comment would attach
// to the first import, which Pkl rejects — entries have no `module` clause.)

amends "lib/entry.pkl"

import "lib/components.pkl" as c
import "lib/dump.pkl" as dump

// Registered popup surfaces: opened by an `openPopup("detail")` tap and
// rendered/streamed only while open. A registered popup wraps its content in the
// `popup` dialog card (symmetric with how the inline `openPopupInline` form
// wraps automatically). Mirrors dashboard.jsonnet:42-52.
surfaces {
  ["detail"] = new c.SurfaceDef {
    content = new c.Popup {
      children {
        c.title("Power detail")
        c.entityCard(dump.entities.`sensor_ams_1a4e_q`)
        c.button("Close", c.closePopup())
      }
    }
  }
}

card = new c.Column {
  children {
    c.title("Pkl demo")

    // Default display: friendly_name label, $state + auto-appended unit.
    c.entityCard(dump.entities.`sensor_ams_1a4e_q`)

    // Live value expression + explicit tap service: entity-first call, options
    // amended onto the result (the outer parens are mandatory).
    (c.entityCard(dump.entities.sensor_ams_1a4e_u1)) {
      value = c.expr(#"$round($number($state), 1) & " V""#)
      tap = c.serviceTap("homeassistant/toggle")
    }

    // Domain-checked: only entities with a sliderSpec row (lights) compile.
    c.slider(dump.entities.`light_skyconnect_v1_0_light_group_overetasje_stue_sittegruppe_gang`)

    // DYNAMIC group with per-domain DISPATCH: one card per live "on" entity, the
    // card chosen by the first matching branch (author order = dispatch order).
    // Each branch is a render lambda of the matched entity; the light branch is a
    // bare `c.slider` value (its action/key/min/max/position resolve per matched
    // light via the runtime $lookup($domain) config tier). `render` is the
    // fallback: every other "on" entity, toggled on tap.
    c.title("Active now")
    new c.DynamicGroup {
      query = c.stateIs("on")
      branches {
        [c.domainIs("light")] = c.slider
      }
      render = (e) -> (c.entityCard(e)) {
        tap = c.toggleTap
        label = c.expr(#"$attr.friendly_name & " (" & $state & ")""#)
      }
    }

    // DYNAMIC group with a SINGLE card and a NUMERIC membership query: every
    // device_class:battery sensor under 20%, tracked live as batteries drain.
    c.title("Low battery")
    new c.DynamicGroup {
      query = c.lowBattery(20)
      render = (e) -> (c.entityCard(e)) {
        label = c.expr(#"$attr.friendly_name & " — " & $state & "%""#)
        secondary = "device_class"
      }
    }

    // POPUPS. The first button opens the REGISTERED `detail` surface; the second
    // opens an INLINE popup whose content the build-phase hoist lifts into a
    // surface (keyed by this button's derived id + "_self").
    c.title("Popups")
    c.button("Power detail…", c.openPopup("detail"))
    c.button("Quick info…", c.openPopupInline(new c.Column {
      children {
        c.title("Quick info")
        c.entityCard(dump.entities.sensor_ams_1a4e_u1)
        c.button("Close", c.closePopup())
      }
    }))

    c.button("« Back to jsonnet", c.navigate("dashboard"))
  }
}
