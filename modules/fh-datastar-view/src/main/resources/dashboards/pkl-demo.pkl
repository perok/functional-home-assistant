// The Pkl-authored demo dashboard, served at /d/pkl-demo (slug = filename)
// next to the jsonnet dashboards. Exercises the MVP component set: entity
// cards (default value, live expr override, tap), a domain-checked slider,
// and cross-dashboard navigation back to the jsonnet default.
//
// `lib/dump.pkl` is GENERATED (by PklDump, from the live HA registry) when
// the server or build runs — like `dump.libsonnet` on the jsonnet track.
// (Plain `//` comments here: a doc comment would attach to the first import,
// which Pkl rejects — entries have no `module` clause to absorb it.)

import "lib/components.pkl" as c
import "lib/theme.pkl" as themeMod
import "lib/dump.pkl" as dump
import "lib/hass.pkl"

cards = c.cards
theme = themeMod.theme

// Registered popup surfaces: opened by an `openPopup("detail")` tap and
// rendered/streamed only while open. A registered popup wraps its content in the
// `popup` dialog card (symmetric with how the inline `openPopupInline` form
// wraps automatically). Mirrors dashboard.jsonnet:42-52.
surfaces: Mapping<String, c.SurfaceDef> = new {
  ["detail"] = new c.SurfaceDef {
    content = new c.Popup {
      children {
        new c.SectionTitle { text = "Power detail" }
        new c.EntityCard { entity = dump.entities.`sensor_ams_1a4e_q` }
        new c.Button { label = "Close"; action = c.closePopup() }
      }
    }
  }
}

card: c.Node = new c.Column {
  children {
    new c.SectionTitle { text = "Pkl demo" }

    // Default display: friendly_name label, $state + auto-appended unit.
    new c.EntityCard { entity = dump.entities.`sensor_ams_1a4e_q` }

    // Live value expression + explicit tap service.
    new c.EntityCard {
      entity = dump.entities.sensor_ams_1a4e_u1
      value = c.expr(#"$round($number($state), 1) & " V""#)
      tap = c.serviceTap("homeassistant/toggle")
    }

    // Domain-checked: only entities with a sliderSpec row (lights) compile.
    new c.Slider { entity = dump.entities.`light_skyconnect_v1_0_light_group_overetasje_stue_sittegruppe_gang` }

    // DYNAMIC group with per-domain DISPATCH: one card per live "on" entity,
    // the card chosen by the first matching branch. Cards are built against
    // hass.SELF (the match placeholder). The light branch is a $self Slider: its
    // action/key/min/max/position resolve per matched light via the runtime
    // $lookup($domain) config tier (plan step 3).
    new c.SectionTitle { text = "Active now" }
    c.groupCases(c.whenState("on"), c.dynWhen(new Listing {
      c.dynCase(c.whenDomain("light"), new c.Slider { entity = hass.SELF })
    }, new c.EntityCard {
      // fallback: every other "on" entity, toggled on tap.
      entity = hass.SELF
      tap = c.toggleTap
      label = c.expr(#"$attr.friendly_name & " (" & $state & ")""#)
    }))

    // DYNAMIC group with a SINGLE card and a NUMERIC membership query: every
    // device_class:battery sensor under 20%, tracked live as batteries drain.
    new c.SectionTitle { text = "Low battery" }
    c.group(c.lowBattery(20), new c.EntityCard {
      entity = hass.SELF
      label = c.expr(#"$attr.friendly_name & " — " & $state & "%""#)
      secondary = "device_class"
    })

    // POPUPS. The first button opens the REGISTERED `detail` surface; the second
    // opens an INLINE popup whose content the build-phase hoist lifts into a
    // surface (keyed by this button's derived id + "_self").
    new c.SectionTitle { text = "Popups" }
    new c.Button { label = "Power detail…"; action = c.openPopup("detail") }
    new c.Button {
      label = "Quick info…"
      action = c.openPopupInline(new c.Column {
        children {
          new c.SectionTitle { text = "Quick info" }
          new c.EntityCard { entity = dump.entities.sensor_ams_1a4e_u1 }
          new c.Button { label = "Close"; action = c.closePopup() }
        }
      })
    }

    new c.Button { label = "« Back to jsonnet"; action = c.navigate("dashboard") }
  }
}

output {
  renderer = new JsonRenderer { omitNullProperties = true }
}
